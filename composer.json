{
    "name": "codraw/workflow",
    "description": "Library to add feature to symfony/workflow.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "draw",
        "workflow",
        "symfony"
    ],
    "authors": [
        {
            "name": "Martin Poirier Theoret",
            "email": "mpoiriert@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/workflow": "^6.4.0"
    },
    "require-dev": {
        "codraw/dependency-injection": "^0.39",
        "codraw/security": "^0.39",
        "phpunit/phpunit": "^11.3 || ^12.0",
        "symfony/security-core": "^6.4.0"
    },
    "suggest": {
        "codraw/dependency-injection": "To use the WorkflowIntegration",
        "codraw/security": "To use the AddUserToContextListener"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\Workflow\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.39-dev"
        }
    },
    "replace": {
        "draw/workflow": "self.version"
    }
}
